page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #eef5fb;
}

.response-page {
  position: fixed;
  inset: 0;
  display: grid;
  place-items: center;
  overflow: hidden;
  padding: 28rpx 124rpx 28rpx 28rpx;
  box-sizing: border-box;
  color: #17253a;
  background:
    radial-gradient(circle at 50% 14%, rgba(11, 108, 255, 0.11), transparent 32%),
    linear-gradient(145deg, #f8fbff 0%, #edf5fb 100%);
}

.response-asset {
  position: absolute;
  top: 18rpx;
  left: 32rpx;
  width: 180rpx;
  height: 180rpx;
  transform: none;
  filter: drop-shadow(0 18rpx 32rpx rgba(20, 53, 94, 0.18));
  animation: responseFloat 4.6s ease-in-out infinite;
}

.answer-zone {
  width: 76vw;
  max-height: 66vh;
  display: grid;
  justify-items: center;
  gap: 22rpx;
  margin-top: 12rpx;
  overflow: hidden;
  text-align: center;
}

.answer-text {
  max-width: 100%;
  color: #17253a;
  font-size: 50rpx;
  font-weight: 950;
  line-height: 1.26;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.keyword-row text {
  padding: 10rpx 16rpx;
  color: #315070;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #dbe5f2;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.audio-pill {
  position: fixed;
  left: 50%;
  bottom: 28rpx;
  display: grid;
  grid-template-columns: 36rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  min-width: 280rpx;
  padding: 10rpx 18rpx 10rpx 12rpx;
  transform: translateX(-50%);
  color: #24415f;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(201, 218, 238, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 26rpx rgba(43, 78, 126, 0.1);
}

.audio-pill text {
  display: block;
  overflow: hidden;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1.18;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audio-pill text + text {
  color: #637990;
  font-size: 15rpx;
}

.audio-dot {
  width: 36rpx;
  height: 36rpx;
  background: #0b6cff;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(11, 108, 255, 0.12);
}

.response-rail {
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  bottom: 14rpx;
  z-index: 30;
  display: grid;
  align-content: center;
  gap: 10rpx;
}

.response-rail button {
  width: 92rpx;
  height: 74rpx;
  color: #20344f;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.14);
  font-size: 19rpx;
  font-weight: 950;
  line-height: 74rpx;
}

.response-rail button::after {
  display: none;
}

@keyframes responseFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@media (max-height: 430px) and (orientation: landscape) {
  .response-asset {
    top: 18rpx;
    left: 22rpx;
    width: 132rpx;
    height: 132rpx;
  }

  .answer-zone {
    width: 74vw;
    max-height: 62vh;
    margin-top: 0;
  }

  .answer-text {
    font-size: 40rpx;
    -webkit-line-clamp: 3;
  }

  .keyword-row,
  .audio-pill {
    transform: scale(0.92);
  }

  .audio-pill {
    transform: translateX(-50%) scale(0.92);
  }
}
