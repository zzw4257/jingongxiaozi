<view class="home">
  <view class="hero-panel">
    <view class="hero-copy">
      <view class="robot-face">
        <view class="eye left"></view>
        <view class="eye right"></view>
        <view class="mouth"></view>
      </view>
      <view>
        <text class="title">金工小子</text>
        <text class="subtitle">金工中心导航</text>
      </view>
    </view>

    <view class="capability-row">
      <text class="capability-chip">选地点</text>
      <text class="capability-chip">看路线</text>
      <text class="capability-chip">转视角</text>
    </view>
  </view>

  <view class="action-panel">
    <view class="entry primary" bindtap="openMap" hover-class="entry-hover">
      <view class="entry-top">
        <text class="entry-title">打开地图</text>
        <text class="entry-badge">总览</text>
      </view>
      <text class="entry-desc">查看全楼，可继续选择起点、终点和楼层。</text>
    </view>

    <view class="section-head">
      <text class="section-title">快速导航</text>
      <text class="section-note">打开后仍可修改路线</text>
    </view>

    <view class="entry-grid">
      <view
        wx:for="{{primaryMapDirects}}"
        wx:key="id"
        class="entry route-entry"
        data-index="{{item.originalIndex}}"
        bindtap="openMapDirect"
        hover-class="entry-hover"
      >
        <view class="entry-top">
          <text class="entry-title">{{item.title}}</text>
          <text class="entry-badge">{{item.badge}}</text>
        </view>
        <text class="entry-desc">{{item.desc}}</text>
      </view>

      <view class="entry route-entry more-entry" bindtap="showMoreRoutes" hover-class="entry-hover">
        <view class="entry-top">
          <text class="entry-title">更多路线</text>
          <text class="entry-badge">展开</text>
        </view>
        <text class="entry-desc">查看服务空间和二层公共房间。</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showMoreRoutes}}" class="route-sheet-mask" bindtap="closeMoreRoutes">
    <view class="route-sheet" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">更多路线</text>
        <button class="sheet-close" bindtap="closeMoreRoutes" hover-class="entry-hover">关闭</button>
      </view>
      <view class="sheet-grid">
        <view
          wx:for="{{secondaryMapDirects}}"
          wx:key="id"
          class="entry"
          data-index="{{item.originalIndex}}"
          bindtap="openMapDirect"
          hover-class="entry-hover"
        >
          <view class="entry-top">
            <text class="entry-title">{{item.title}}</text>
            <text class="entry-badge">{{item.badge}}</text>
          </view>
          <text class="entry-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showMapUnavailable}}" class="route-sheet-mask" bindtap="closeMapUnavailable">
    <view class="route-sheet notice-sheet" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">地图服务未连接</text>
        <button class="sheet-close" bindtap="closeMapUnavailable" hover-class="entry-hover">关闭</button>
      </view>
      <text class="notice-desc">当前仍是本地调试地址。小程序正式版必须配置 HTTPS 业务域名，连接完成后会直接打开同一套金工中心地图。</text>
    </view>
  </view>
</view>
