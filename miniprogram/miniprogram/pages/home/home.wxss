.home {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: #f4f8ff;
}

.hero-panel {
  box-sizing: border-box;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #ffffff 0%, #edf5ff 100%);
  box-shadow: 0 18rpx 46rpx rgba(30, 73, 128, 0.1);
}

.hero-copy {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.robot-face {
  position: relative;
  width: 168rpx;
  height: 132rpx;
  border-radius: 48rpx;
  background: linear-gradient(145deg, #ffad22, #ff7d18);
  box-shadow: 0 24rpx 64rpx rgba(37, 87, 160, 0.16);
  flex: 0 0 auto;
}

.robot-face::before {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 34rpx;
  height: 70rpx;
  content: "";
  border-radius: 34rpx;
  background: #10213d;
}

.eye {
  position: absolute;
  z-index: 1;
  top: 58rpx;
  width: 18rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #26d6ff;
  box-shadow: 0 0 24rpx rgba(38, 214, 255, 0.62);
}

.eye.left {
  left: 58rpx;
}

.eye.right {
  right: 58rpx;
}

.mouth {
  position: absolute;
  z-index: 1;
  left: 72rpx;
  top: 88rpx;
  width: 26rpx;
  height: 12rpx;
  border-bottom: 6rpx solid #26d6ff;
  border-radius: 0 0 999rpx 999rpx;
}

.title {
  display: block;
  color: #162640;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.08;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #5f7590;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.25;
}

.capability-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  max-width: 420rpx;
}

.capability-chip {
  padding: 10rpx 16rpx;
  color: #1357aa;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 999rpx;
  background: #e0eeff;
}

.action-panel {
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.entry {
  box-sizing: border-box;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 132rpx;
  margin: 0;
  padding: 22rpx 24rpx;
  text-align: left;
  background: #ffffff;
  border: 2rpx solid #dce8f6;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(40, 82, 135, 0.07);
}

.entry::after {
  display: none;
}

.entry.primary {
  min-height: 148rpx;
  color: #ffffff;
  background: #1769e0;
  border-color: #1769e0;
  box-shadow: 0 18rpx 42rpx rgba(23, 105, 224, 0.22);
}

.entry-hover {
  transform: scale(0.985);
  opacity: 0.9;
}

.entry-top {
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.entry-title {
  min-width: 0;
  flex: 1 1 auto;
  color: #17253a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.18;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.entry-badge {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  color: #1769e0;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.entry-desc {
  color: #697e96;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.entry.primary .entry-title {
  color: #ffffff;
}

.entry.primary .entry-desc {
  color: rgba(255, 255, 255, 0.82);
}

.entry.primary .entry-badge {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.2);
}

.more-entry {
  border-style: dashed;
  background: #f8fbff;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  color: #17253a;
  font-size: 28rpx;
  font-weight: 900;
}

.section-note {
  color: #6b7f96;
  font-size: 22rpx;
  font-weight: 700;
  text-align: right;
}

.status {
  display: none;
  padding: 18rpx 22rpx;
  color: #5f7188;
  background: rgba(255, 255, 255, 0.74);
  border: 2rpx solid #dce9f7;
  border-radius: 20rpx;
}

.status-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.status-value {
  display: block;
  word-break: break-all;
  font-size: 22rpx;
  line-height: 1.45;
}

.route-sheet-mask {
  position: fixed;
  z-index: 999;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: rgba(15, 31, 52, 0.28);
  box-sizing: border-box;
}

.route-sheet {
  width: 650rpx;
  max-width: 88vw;
  max-height: calc(100vh - 56rpx);
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 30rpx 90rpx rgba(20, 44, 75, 0.28);
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 18rpx;
}

.sheet-title {
  color: #17253a;
  font-size: 30rpx;
  font-weight: 900;
}

.sheet-close {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  color: #1769e0;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.sheet-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.notice-sheet {
  max-width: 620rpx;
}

.notice-desc {
  display: block;
  color: #5e7289;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
}

@media (orientation: landscape) {
  .home {
    height: 100vh;
    overflow: hidden;
    flex-direction: row;
    align-items: stretch;
    gap: 20rpx;
    padding: 20rpx max(24rpx, env(safe-area-inset-right)) 20rpx max(72rpx, env(safe-area-inset-left));
  }

  .hero-panel {
    width: 26vw;
    min-width: 260rpx;
    max-width: 320rpx;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    padding: 24rpx;
  }

  .hero-copy {
    flex-direction: column;
    align-items: flex-start;
    gap: 18rpx;
  }

  .capability-row {
    display: none;
  }

  .action-panel {
    flex: 1;
    justify-content: flex-start;
  }

  .entry-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr)) 0.78fr;
    gap: 12rpx;
  }

  .entry {
    min-height: 94rpx;
    padding: 16rpx 18rpx;
    border-radius: 20rpx;
  }

  .route-entry {
    justify-content: center;
    gap: 8rpx;
  }

  .route-entry .entry-top {
    align-items: center;
    justify-content: center;
  }

  .route-entry .entry-title {
    flex: 0 1 auto;
    width: 100%;
    text-align: center;
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    font-size: 23rpx;
    line-height: 1.16;
  }

  .more-entry .entry-title {
    font-size: 21rpx;
  }

  .entry.primary {
    min-height: 108rpx;
    padding: 18rpx 20rpx;
  }

  .route-entry .entry-desc {
    display: none;
  }

  .route-entry .entry-badge {
    display: none;
  }

  .entry-desc {
    font-size: 20rpx;
  }

  .entry-badge {
    padding: 6rpx 10rpx;
    font-size: 18rpx;
  }

  .section-note {
    display: none;
  }

  .route-sheet {
    width: 720rpx;
    max-width: 72vw;
    max-height: calc(100vh - 40rpx);
    padding: 22rpx;
  }

  .route-sheet-mask {
    padding: 20rpx max(24rpx, env(safe-area-inset-right)) 20rpx max(72rpx, env(safe-area-inset-left));
  }

  .sheet-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 520px) and (orientation: portrait) {
  .home {
    padding: 24rpx;
    gap: 18rpx;
  }

  .hero-panel {
    align-items: flex-start;
    flex-direction: column;
    gap: 16rpx;
    padding: 24rpx;
  }

  .capability-row {
    justify-content: flex-start;
  }
}
