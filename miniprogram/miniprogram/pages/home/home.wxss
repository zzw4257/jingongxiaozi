page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #eef5fb;
}

.home {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 25% 24%, rgba(8, 110, 255, 0.08), transparent 30%),
    linear-gradient(145deg, #f7fbff 0%, #eef5fb 100%);
}

.standby-stage {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  padding: 20rpx;
  -webkit-tap-highlight-color: transparent;
}

.standby-stage.standby-hover,
.entry-hover {
  opacity: 0.92;
  transform: scale(0.988);
}

.robot-expression-image {
  width: 88vw;
  height: 88vh;
  filter: drop-shadow(0 32rpx 56rpx rgba(20, 53, 94, 0.22));
  transform: scale(1.1);
  animation: robotFloat 5.4s ease-in-out infinite;
}

.drawer-handle {
  position: fixed;
  left: 0;
  top: 50%;
  z-index: 50;
  width: 52rpx;
  height: 96rpx;
  display: grid;
  place-items: center;
  transform: translateY(-50%);
  border-radius: 0 30rpx 30rpx 0;
  background: rgba(11, 108, 255, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(7, 91, 212, 0.24);
}

.drawer-handle.entry-hover {
  transform: translateY(-50%) scale(0.985);
}

.drawer-dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 -22rpx 0 rgba(255, 255, 255, 0.86), 0 22rpx 0 rgba(255, 255, 255, 0.86);
}

.map-fab {
  position: fixed;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 60;
  width: 116rpx;
  height: 116rpx;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 2rpx;
  color: #ffffff;
  border-radius: 32rpx;
  background: #0b6cff;
  box-shadow: 0 14rpx 34rpx rgba(7, 91, 212, 0.28);
  -webkit-tap-highlight-color: transparent;
}

.fab-icon {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 950;
}

.fab-label {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 950;
}

.sheet-mask {
  position: fixed;
  z-index: 900;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  box-sizing: border-box;
  padding: 20rpx 22rpx 20rpx 64rpx;
  background: rgba(16, 31, 55, 0.18);
}

.drawer-mask {
  justify-content: flex-start;
}

.app-drawer,
.route-sheet {
  box-sizing: border-box;
  width: min(560rpx, 48vw);
  max-height: 88vh;
  padding: 22rpx;
  overflow: hidden;
  border: 2rpx solid rgba(201, 218, 238, 0.96);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 62rpx rgba(20, 53, 94, 0.24);
}

.route-sheet {
  width: min(760rpx, 68vw);
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.sheet-title {
  color: #17253a;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.1;
}

.sheet-close {
  min-width: 100rpx;
  min-height: 54rpx;
  padding: 0 18rpx;
  color: #31516f;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 54rpx;
  border-radius: 999rpx;
  background: #f4f8fd;
}

.sheet-close::after,
.route-entry::after {
  display: none;
}

.drawer-item {
  display: grid;
  grid-template-columns: 78rpx minmax(0, 1fr);
  align-items: center;
  gap: 14rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 14rpx;
  border: 2rpx solid #d8e4f3;
  border-radius: 24rpx;
  background: rgba(248, 251, 255, 0.94);
}

.drawer-item.primary {
  color: #ffffff;
  border-color: #075bd4;
  background: linear-gradient(135deg, #075bd4 0%, #1682ff 100%);
  box-shadow: 0 20rpx 38rpx rgba(7, 91, 212, 0.22);
}

.drawer-item.muted {
  opacity: 0.82;
}

.drawer-item-asset {
  width: 72rpx;
  height: 72rpx;
  filter: drop-shadow(0 10rpx 18rpx rgba(20, 53, 94, 0.14));
}

.drawer-item-icon {
  width: 58rpx;
  height: 58rpx;
  display: grid;
  place-items: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 950;
  border-radius: 18rpx;
  background: #0b6cff;
}

.drawer-item-copy {
  min-width: 0;
  display: grid;
  gap: 4rpx;
}

.drawer-item-title {
  color: #17253a;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 1.15;
}

.drawer-item.primary .drawer-item-title,
.drawer-item.primary .drawer-item-desc {
  color: #ffffff;
}

.drawer-item-desc {
  color: #61748d;
  font-size: 19rpx;
  font-weight: 850;
  line-height: 1.28;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.route-entry {
  min-height: 108rpx;
  box-sizing: border-box;
  padding: 16rpx;
  text-align: left;
  border: 2rpx solid #dce8f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(40, 82, 135, 0.07);
}

.route-entry.secondary {
  background: #f8fbff;
}

.route-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 9rpx;
}

.route-title {
  min-width: 0;
  color: #17253a;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 1.15;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.route-badge {
  flex: 0 0 auto;
  padding: 7rpx 10rpx;
  color: #1769e0;
  font-size: 17rpx;
  font-weight: 950;
  line-height: 1;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.route-desc {
  color: #667c95;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 1.28;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

@keyframes robotFloat {
  0%, 100% { transform: scale(1.1) translateY(0) rotate(-0.4deg); }
  50% { transform: scale(1.1) translateY(-12rpx) rotate(0.4deg); }
}

@media (max-width: 700px) and (orientation: landscape) {
  .robot-expression-image {
    width: 84vw;
    height: 84vh;
    transform: scale(1.02);
  }

  .map-fab {
    width: 104rpx;
    height: 104rpx;
    border-radius: 30rpx;
  }

  .app-drawer {
    width: 52vw;
    padding: 18rpx;
  }

  .route-sheet {
    width: 72vw;
    padding: 18rpx;
  }

  .drawer-item-desc {
    display: none;
  }

  .route-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .route-desc {
    -webkit-line-clamp: 1;
  }
}

@media (orientation: portrait) {
  .robot-expression-image {
    width: 88vw;
    height: 68vh;
  }

  .sheet-mask,
  .drawer-mask {
    justify-content: center;
    align-items: flex-end;
    padding: 24rpx;
  }

  .app-drawer,
  .route-sheet {
    width: 100%;
    max-height: 78vh;
  }

  .route-grid {
    grid-template-columns: 1fr;
  }
}
