page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #eef5fb;
}

.home {
  position: fixed;
  inset: 0;
  box-sizing: border-box;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 28% 24%, rgba(16, 126, 255, 0.12), transparent 29%),
    linear-gradient(145deg, #f8fbff 0%, #edf5fb 100%);
}

.standby-stage {
  position: absolute;
  left: 50%;
  top: 46%;
  width: 62vw;
  max-width: 860rpx;
  height: 66vh;
  max-height: 620rpx;
  transform: translate(-50%, -50%);
  display: grid;
  place-items: center;
  -webkit-tap-highlight-color: transparent;
}

.entry-hover {
  transform: scale(0.985);
  opacity: 0.9;
}

.standby-stage.standby-hover {
  transform: translate(-50%, -50%) scale(0.985);
  opacity: 0.9;
}

.robot-shell {
  position: relative;
  z-index: 2;
  width: 44vw;
  max-width: 540rpx;
  height: 46vh;
  max-height: 380rpx;
  display: grid;
  place-items: center;
  animation: robotFloat 5.2s ease-in-out infinite;
}

.robot-antenna {
  position: absolute;
  top: 2%;
  width: 82rpx;
  height: 52rpx;
  border-top: 8rpx solid #ff9d28;
  border-left: 8rpx solid #ff9d28;
  border-right: 8rpx solid #ff9d28;
  border-radius: 999rpx 999rpx 0 0;
}

.robot-face {
  position: relative;
  width: 100%;
  height: 68%;
  border-radius: 54rpx;
  background: linear-gradient(145deg, #ffae2e, #f47718);
  box-shadow:
    inset 0 -18rpx 28rpx rgba(125, 55, 0, 0.26),
    0 34rpx 72rpx rgba(21, 56, 96, 0.24);
}

.robot-face::before,
.robot-face::after {
  position: absolute;
  top: 34%;
  width: 32rpx;
  height: 86rpx;
  content: "";
  border-radius: 999rpx;
  background: #1d2a3a;
}

.robot-face::before {
  left: -18rpx;
}

.robot-face::after {
  right: -18rpx;
}

.face-screen {
  position: absolute;
  left: 12%;
  right: 12%;
  top: 20%;
  bottom: 18%;
  border-radius: 34rpx;
  background: radial-gradient(circle at 52% 10%, #25466e, #07192d 70%);
  border: 8rpx solid #16243a;
  box-shadow: inset 0 0 34rpx rgba(92, 175, 255, 0.2);
}

.eye {
  position: absolute;
  top: 38%;
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: #f8fcff;
  box-shadow: 0 0 24rpx rgba(75, 200, 255, 0.88);
  animation: eyeBlink 5.6s infinite;
}

.eye.left {
  left: 25%;
}

.eye.right {
  right: 25%;
}

.mouth {
  position: absolute;
  left: 50%;
  bottom: 18%;
  width: 74rpx;
  height: 30rpx;
  border-bottom: 8rpx solid #53d9ff;
  border-radius: 0 0 999rpx 999rpx;
  transform: translateX(-50%);
}

.robot-neck {
  position: absolute;
  bottom: 0;
  width: 116rpx;
  height: 58rpx;
  border-radius: 0 0 28rpx 28rpx;
  background: #26384f;
  box-shadow: 0 18rpx 34rpx rgba(21, 56, 96, 0.16);
}

.voice-orbit {
  position: absolute;
  z-index: 1;
  border: 3rpx solid rgba(23, 105, 224, 0.18);
  border-radius: 999rpx;
  animation: pulseRing 2.8s ease-out infinite;
}

.orbit-a {
  width: 78%;
  height: 66%;
}

.orbit-b {
  width: 96%;
  height: 80%;
  animation-delay: 900ms;
}

.standby-copy {
  position: absolute;
  left: 50%;
  bottom: max(40rpx, env(safe-area-inset-bottom));
  display: grid;
  justify-items: center;
  gap: 8rpx;
  width: 60vw;
  max-width: 620rpx;
  transform: translateX(-50%);
  pointer-events: none;
}

.eyebrow {
  padding: 8rpx 18rpx;
  color: #075bd4;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 999rpx;
  background: rgba(219, 234, 255, 0.88);
}

.title {
  color: #162640;
  font-size: 64rpx;
  font-weight: 950;
  line-height: 1.02;
}

.subtitle {
  color: #60748e;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
}

.drawer-handle {
  position: fixed;
  left: max(0rpx, env(safe-area-inset-left));
  top: 50%;
  z-index: 50;
  width: 52rpx;
  height: 96rpx;
  display: grid;
  place-items: center;
  transform: translateY(-50%);
  border-radius: 0 30rpx 30rpx 0;
  background: rgba(11, 108, 255, 0.88);
  box-shadow: 0 18rpx 42rpx rgba(7, 91, 212, 0.24);
}

.drawer-handle.entry-hover {
  transform: translateY(-50%) scale(0.985);
  opacity: 0.9;
}

.drawer-dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 -22rpx 0 rgba(255, 255, 255, 0.86), 0 22rpx 0 rgba(255, 255, 255, 0.86);
}

.map-fab {
  position: fixed;
  right: max(22rpx, env(safe-area-inset-right));
  bottom: max(22rpx, env(safe-area-inset-bottom));
  z-index: 60;
  width: 128rpx;
  height: 128rpx;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 4rpx;
  color: #ffffff;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #1682ff, #075bd4);
  box-shadow: 0 22rpx 52rpx rgba(7, 91, 212, 0.34);
  -webkit-tap-highlight-color: transparent;
}

.fab-icon {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 900;
}

.fab-label {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 950;
}

.sheet-mask {
  position: fixed;
  z-index: 900;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx max(22rpx, env(safe-area-inset-right)) 20rpx max(64rpx, env(safe-area-inset-left));
  background: rgba(16, 31, 55, 0.22);
}

.drawer-mask {
  justify-content: flex-start;
}

.app-drawer,
.route-sheet {
  box-sizing: border-box;
  width: 46vw;
  max-width: 640rpx;
  max-height: calc(100vh - 40rpx);
  padding: 22rpx;
  border: 2rpx solid rgba(207, 226, 255, 0.96);
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 30rpx 80rpx rgba(22, 45, 78, 0.24);
}

.route-sheet {
  width: 58vw;
  max-width: 760rpx;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.sheet-title {
  color: #17253a;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.1;
}

.sheet-close {
  min-width: 108rpx;
  padding: 14rpx 18rpx;
  color: #1769e0;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.sheet-close::after {
  display: none;
}

.drawer-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 86rpx;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border: 2rpx solid #d8e4f3;
  border-radius: 24rpx;
  background: #f8fbff;
}

.drawer-item.primary {
  border-color: #cfe2ff;
  background: #edf5ff;
}

.drawer-item.muted {
  opacity: 0.78;
}

.drawer-item-icon {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  display: grid;
  place-items: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 950;
  border-radius: 18rpx;
  background: #0b6cff;
}

.drawer-item-copy {
  min-width: 0;
  display: grid;
  gap: 4rpx;
}

.drawer-item-title {
  color: #17253a;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1.1;
}

.drawer-item-desc {
  color: #667c95;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.route-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.route-entry {
  min-height: 112rpx;
  box-sizing: border-box;
  padding: 18rpx;
  border: 2rpx solid #dce8f6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(40, 82, 135, 0.07);
}

.route-entry.secondary {
  background: #f8fbff;
}

.route-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.route-title {
  min-width: 0;
  color: #17253a;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 1.15;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.route-badge {
  flex: 0 0 auto;
  padding: 7rpx 10rpx;
  color: #1769e0;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.route-desc,
.notice-desc {
  color: #667c95;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.32;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notice-sheet {
  width: 54vw;
  max-width: 650rpx;
}

@keyframes robotFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

@keyframes pulseRing {
  0% {
    opacity: 0.55;
    transform: scale(0.92);
  }
  100% {
    opacity: 0;
    transform: scale(1.16);
  }
}

@keyframes eyeBlink {
  0%,
  88%,
  100% {
    transform: scaleY(1);
  }
  92% {
    transform: scaleY(0.12);
  }
}

@media (orientation: portrait) {
  .standby-stage {
    top: 43%;
    width: 82vw;
    height: 58vh;
  }

  .robot-shell {
    width: 70vw;
    height: 40vh;
  }

  .standby-copy {
    width: 74vw;
    bottom: 158rpx;
  }

  .sheet-mask,
  .drawer-mask {
    justify-content: center;
    align-items: flex-end;
    padding: 24rpx;
  }

  .app-drawer,
  .route-sheet,
  .notice-sheet {
    width: 100%;
    max-height: 78vh;
  }

  .route-grid {
    grid-template-columns: 1fr;
  }
}
