<view class="native-map-page layer-{{layerMode}} panel-{{panel}}">
  <view class="map-stage">
    <view class="map-ambient map-ambient-a"></view>
    <view class="map-ambient map-ambient-b"></view>
    <canvas
      id="mapCanvas"
      canvas-id="mapCanvas"
      type="2d"
      class="map-canvas"
      style="width:100%;height:100%;"
      bindtap="handleCanvasTap"
      bindtouchstart="handleTouchStart"
      bindtouchmove="handleTouchMove"
      bindtouchend="handleTouchEnd"
      bindtouchcancel="handleTouchEnd"
    ></canvas>
  </view>

  <view class="map-compass">
    <text class="north-arrow">N</text>
    <view>
      <text>真北</text>
      <text>{{sensorHint}}</text>
    </view>
  </view>

  <view class="map-legend">
    <view><text class="legend-dot corridor"></text><text>走廊</text></view>
    <view><text class="legend-dot room"></text><text>房间</text></view>
    <view><text class="legend-dot stair"></text><text>楼梯</text></view>
    <view><text class="legend-dot route"></text><text>路线</text></view>
  </view>

  <view class="layer-status-pill">
    <text>{{layerHint}}</text>
    <text wx:if="{{hasRoute}}">{{route.summary}} · {{routeDistanceLabel}}</text>
  </view>

  <view wx:if="{{hasRoute}}" class="map3d-guidance-strip">
    <text class="guidance-strip-step">{{activeStepLabel}}</text>
    <view class="guidance-strip-node">
      <text>当前</text>
      <text class="guidance-strong">{{currentStepTitle}}</text>
    </view>
    <text class="guidance-arrow">→</text>
    <view class="guidance-strip-node next">
      <text>下一处</text>
      <text class="guidance-strong">{{nextStepTitle}}</text>
    </view>
    <text class="guidance-strip-distance">{{routeDistanceLabel}}</text>
  </view>

  <view wx:else class="map3d-bottom-chip">
    <image src="/assets/ui/map-building-pin.png" mode="aspectFit"></image>
    <view>
      <text>金工中心地图</text>
      <text>点击房间或选择终点开始导引</text>
    </view>
  </view>

  <view class="map-rail">
    <button bindtap="goBack">返回</button>
    <button class="{{routeButtonClass}}" data-panel="route" bindtap="openPanel">路线</button>
    <button class="{{layersButtonClass}}" data-panel="layers" bindtap="openPanel">图层</button>
    <button class="{{roomButtonClass}}" data-panel="room" bindtap="openPanel">房间</button>
  </view>

  <view wx:if="{{panel !== 'none'}}" class="panel-shade" bindtap="closePanel"></view>
  <view wx:if="{{panel !== 'none'}}" class="material-panel panel-{{panel}}">
    <view wx:if="{{panel === 'route'}}" class="panel-card">
      <view class="panel-head">
        <text class="panel-title">路线引导</text>
        <text class="panel-meta">{{routeDistanceLabel}}</text>
        <button class="panel-close" bindtap="closePanel">×</button>
      </view>
      <view wx:if="{{hasRoute}}" class="route-summary">
        <text>{{route.summary}}</text>
      </view>
      <view wx:else class="route-summary muted">
        <text>选择终点后按门、走廊、楼梯逐段导引。</text>
      </view>
      <scroll-view class="step-strip" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view wx:for="{{routeSteps}}" wx:key="id" class="{{item.className}}">
          <text class="step-no">{{item.no}}</text>
          <text class="step-title">{{item.title}}</text>
          <text class="step-desc">{{item.desc}}</text>
        </view>
      </scroll-view>
      <view class="quick-row">
        <button wx:for="{{quickTargets}}" wx:key="id" data-id="{{item.id}}" bindtap="selectQuickTarget">{{item.label}}</button>
        <button class="plain" bindtap="clearRoute">清路线</button>
      </view>
    </view>

    <view wx:if="{{panel === 'layers'}}" class="panel-card">
      <view class="panel-head">
        <text class="panel-title">图层</text>
        <text class="panel-meta">默认分层总览</text>
        <button class="panel-close" bindtap="closePanel">×</button>
      </view>
      <view class="layer-grid">
        <button class="{{allLayerClass}}" data-layer="all" bindtap="setLayer">全楼</button>
        <button class="{{layer1FClass}}" data-layer="1F" bindtap="setLayer">一层</button>
        <button class="{{layer2FClass}}" data-layer="2F" bindtap="setLayer">二层</button>
        <button class="{{layer25FClass}}" data-layer="25F" bindtap="setLayer">二层半</button>
      </view>
      <view class="panel-note">全楼用于看跨层关系；单层会自动放大并展开更多标签。</view>
    </view>

    <view wx:if="{{panel === 'room'}}" class="panel-card">
      <view class="panel-head">
        <text class="panel-title">空间信息</text>
        <text class="panel-meta">{{selectedFloorLabel}}</text>
        <button class="panel-close" bindtap="closePanel">×</button>
      </view>
      <view wx:if="{{selectedRoom}}" class="room-detail">
        <text class="detail-title">{{selectedRoom.no}} · {{selectedRoom.name}}</text>
        <text class="detail-desc">类型：{{selectedRoom.area}}。路线会从房间中心到门点，再进入走廊或楼梯。</text>
        <button class="start-route-button" data-id="{{selectedRoom.id}}" bindtap="selectQuickTarget">导航到这里</button>
      </view>
      <view wx:else class="room-detail muted">
        <text>点击地图中的房间查看信息。</text>
      </view>
    </view>
  </view>
</view>
