page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #edf5ff;
}

.native-map-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  color: #17253a;
  background:
    radial-gradient(circle at 46% 48%, rgba(80, 132, 196, 0.16), transparent 38%),
    linear-gradient(180deg, #f8fbff 0%, #edf5ff 100%);
}

.map-stage {
  position: absolute;
  left: 0;
  top: 0;
  right: 104rpx;
  bottom: 0;
  overflow: hidden;
  perspective: 1150rpx;
}

.map-ambient {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.map-ambient-a {
  left: 16vw;
  top: 12vh;
  width: 42vw;
  height: 42vw;
  background: radial-gradient(circle, rgba(11, 108, 255, 0.12), transparent 64%);
}

.map-ambient-b {
  right: 12vw;
  bottom: 8vh;
  width: 34vw;
  height: 34vw;
  background: radial-gradient(circle, rgba(255, 154, 0, 0.12), transparent 62%);
}

.map-asset {
  position: absolute;
  left: 18rpx;
  top: 78rpx;
  width: 96rpx;
  height: 96rpx;
  z-index: 5;
  opacity: 0.78;
  filter: drop-shadow(0 12rpx 24rpx rgba(20, 53, 94, 0.14));
}

.floor-deck {
  position: absolute;
  left: 51%;
  top: 55%;
  width: 80vw;
  max-width: 1060rpx;
  height: 56vh;
  max-height: 620rpx;
  transform-origin: center;
}

.layer-all .floor-deck {
  transform:
    translate(calc(-50% + (var(--floor-index) * 30rpx)), calc(-50% - (var(--floor-index) * 66rpx)))
    rotateX(53deg)
    rotateZ(-10deg)
    scale(0.84);
}

.layer-1F .floor-deck,
.layer-2F .floor-deck,
.layer-25F .floor-deck {
  left: 50%;
  top: 54%;
  width: 84vw;
  height: 62vh;
  transform: translate(-50%, -50%) rotateX(48deg) rotateZ(-7deg) scale(0.94);
}

.layer-25F .floor-deck {
  top: 56%;
  width: 66vw;
  height: 48vh;
  transform: translate(-50%, -50%) rotateX(47deg) rotateZ(-7deg) scale(1);
}

.floor-slab {
  position: absolute;
  inset: 0;
  border: 3rpx solid #7c8ea4;
  border-radius: 24rpx;
  background: #f8fbff;
  box-shadow:
    0 18rpx 0 #c7d8ea,
    0 34rpx 58rpx rgba(20, 53, 94, 0.18);
}

.floor-2F .floor-slab {
  background: #f4f8ff;
  border-color: #6e86a2;
}

.floor-25F .floor-slab {
  background: #fff8ed;
  border-color: #d18d2d;
}

.floor-title {
  position: absolute;
  left: 18rpx;
  top: 16rpx;
  z-index: 4;
  padding: 8rpx 14rpx;
  color: #17253a;
  font-size: 18rpx;
  font-weight: 950;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(20, 53, 94, 0.12);
}

.corridor,
.room {
  position: absolute;
  z-index: 5;
  box-sizing: border-box;
}

.corridor {
  display: grid;
  place-items: center;
  color: #075985;
  font-size: 14rpx;
  font-weight: 950;
  border: 2rpx solid rgba(30, 136, 203, 0.56);
  border-radius: 10rpx;
  background:
    repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.22) 0 8rpx, transparent 8rpx 16rpx),
    rgba(216, 242, 255, 0.96);
}

.room {
  display: grid;
  align-content: center;
  justify-items: center;
  gap: 3rpx;
  padding: 6rpx;
  border: 3rpx solid rgba(77, 102, 132, 0.78);
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: inset 0 -7rpx 0 rgba(69, 89, 112, 0.08);
}

.area-workshop { background: #fff0d8; border-color: #c7781e; }
.area-public { background: #e7f2ff; border-color: #2d7eea; }
.area-service { background: #e8f7f0; border-color: #23a26d; }
.area-utility { background: #eef1f5; border-color: #8a98aa; }
.area-mezzanine { background: #ffe9c5; border-color: #d18d2d; }
.area-stair { background: #fff3dc; border-color: #e69a25; }

.room.active {
  color: #ffffff;
  border-color: #0b6cff;
  background: #0b6cff;
  box-shadow: 0 0 0 6rpx rgba(11, 108, 255, 0.16), inset 0 -7rpx 0 rgba(0, 40, 105, 0.12);
}

.room-no {
  color: #17253a;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1.05;
}

.room.active .room-no,
.room.active .room-name {
  color: #ffffff;
}

.room-name {
  max-width: 100%;
  color: #586d84;
  font-size: 12rpx;
  font-weight: 850;
  line-height: 1.1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.stair,
.route-node {
  position: absolute;
  z-index: 12;
  transform: translate(-50%, -50%);
}

.stair {
  width: 78rpx;
  height: 58rpx;
  display: grid;
  place-items: center;
  border-radius: 12rpx;
  background: linear-gradient(145deg, #fff0c9, #ffbe4d);
  border: 3rpx solid #dc8a17;
  box-shadow: 0 12rpx 0 #c87913, 0 20rpx 24rpx rgba(130, 77, 0, 0.22);
}

.stair.active { background: #ffb12b; border-color: #c76700; }

.stair text {
  position: absolute;
  left: 50%;
  top: -25rpx;
  width: 132rpx;
  transform: translateX(-50%);
  color: #7a4300;
  font-size: 14rpx;
  font-weight: 950;
  text-align: center;
}

.stair-treads { display: grid; gap: 4rpx; width: 48rpx; transform: skewX(-14deg); }
.stair-treads text { display: block; height: 5rpx; border-radius: 999rpx; background: rgba(101, 57, 0, 0.78); box-shadow: 0 2rpx 0 rgba(255,255,255,0.35); }

.route-node {
  width: 38rpx;
  height: 38rpx;
  display: grid;
  place-items: center;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 950;
  border-radius: 999rpx;
  background: #0b6cff;
  box-shadow: 0 0 0 8rpx rgba(11, 108, 255, 0.18), 0 12rpx 28rpx rgba(11, 108, 255, 0.26);
}

.route-node.stair-node { background: #ff9a00; }
.route-node.current { width: 46rpx; height: 46rpx; background: #18a058; }
.route-node.target { width: 50rpx; height: 50rpx; background: #ff3f6c; }

.map3d-north-indicator {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  z-index: 20;
  display: inline-grid;
  grid-template-columns: 42rpx auto;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 7rpx 14rpx 7rpx 7rpx;
  color: #17324f;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(188, 210, 232, 0.9);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 53, 94, 0.14);
  font-size: 18rpx;
  font-weight: 950;
}

.north-arrow {
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: #17253a;
  border-radius: 50%;
}

.map3d-north-indicator text {
  display: block;
  line-height: 1.12;
}

.map3d-north-indicator text + text {
  margin-top: 3rpx;
  color: #687a90;
  font-size: 13rpx;
  font-weight: 850;
}

.layer-status-pill {
  position: absolute;
  left: 18rpx;
  top: 82rpx;
  z-index: 22;
  max-width: 520rpx;
  padding: 9rpx 15rpx;
  color: #1a3551;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(201, 218, 238, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.11);
}

.layer-status-pill text {
  display: inline;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1.1;
}

.layer-status-pill text + text {
  margin-left: 12rpx;
  color: #657990;
  font-size: 15rpx;
  font-weight: 850;
}

.map3d-bottom-chip {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  z-index: 18;
  display: grid;
  grid-template-columns: 50rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  max-width: 560rpx;
  min-height: 54rpx;
  padding: 8rpx 14rpx 8rpx 9rpx;
  color: #20344f;
  background: rgba(255, 255, 255, 0.93);
  border: 2rpx solid rgba(207, 222, 241, 0.94);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 53, 94, 0.12);
}

.map3d-bottom-chip image { width: 48rpx; height: 48rpx; }
.map3d-bottom-chip text { display: block; overflow: hidden; font-size: 18rpx; font-weight: 950; text-overflow: ellipsis; white-space: nowrap; }
.map3d-bottom-chip text + text { color: #5e7189; font-size: 14rpx; font-weight: 850; }

.map3d-guidance-strip {
  position: absolute;
  left: 14rpx;
  bottom: 14rpx;
  z-index: 28;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto minmax(0, 1.08fr) auto;
  align-items: center;
  gap: 9rpx;
  max-width: 720rpx;
  min-height: 58rpx;
  padding: 8rpx 10rpx;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(15, 28, 44, 0.94), rgba(7, 65, 135, 0.92));
  border: 2rpx solid rgba(146, 202, 255, 0.42);
  border-radius: 26rpx;
  box-shadow: 0 18rpx 38rpx rgba(6, 24, 56, 0.28);
}

.guidance-strip-step {
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: #1ac46d;
  border-radius: 50%;
  font-size: 14rpx;
  font-weight: 950;
}

.guidance-strip-node { min-width: 0; }
.guidance-strip-node text { display: block; overflow: hidden; color: rgba(226, 238, 255, 0.74); font-size: 13rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.guidance-strip-node .guidance-strong { color: #ffffff; font-size: 17rpx; font-weight: 950; }
.guidance-strip-node.next .guidance-strong { color: #bfe0ff; }
.guidance-arrow { color: rgba(255, 255, 255, 0.6); font-size: 18rpx; font-weight: 950; }
.guidance-strip-distance { display: grid; place-items: center; min-width: 52rpx; min-height: 34rpx; padding: 0 10rpx; color: #ffffff; background: rgba(255, 255, 255, 0.14); border-radius: 999rpx; font-size: 15rpx; font-weight: 950; }

.map-rail {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  z-index: 34;
  display: grid;
  align-content: center;
  gap: 9rpx;
}

.map-rail button {
  display: grid;
  place-items: center;
  width: 92rpx;
  height: 74rpx;
  padding: 0;
  color: #20344f;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.14);
  font-size: 19rpx;
  font-weight: 950;
  line-height: 74rpx;
}

.map-rail button::after,
.panel-close::after,
.quick-row button::after,
.layer-grid button::after { display: none; }
.map-rail button.active { color: #ffffff; background: #0b6cff; }

.material-panel {
  position: absolute;
  right: 118rpx;
  top: auto;
  bottom: 16rpx;
  z-index: 40;
  width: min(660rpx, 62vw);
  min-height: 178rpx;
  max-height: 74vh;
  box-sizing: border-box;
  padding: 16rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid rgba(201, 218, 238, 0.96);
  border-radius: 32rpx;
  box-shadow: 0 22rpx 58rpx rgba(20, 53, 94, 0.26);
}

.panel-card { display: grid; gap: 10rpx; }
.panel-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  align-items: center;
  gap: 14rpx;
}
.panel-title { color: #17253a; font-size: 26rpx; font-weight: 950; }
.panel-meta { color: #0b6cff; font-size: 20rpx; font-weight: 950; }
.panel-close {
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  color: #405875;
  background: #eef4fb;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 44rpx;
}
.route-summary,
.room-detail { color: #566a82; font-size: 20rpx; font-weight: 850; }
.muted { color: #7b8da3; }

.step-strip { width: 100%; white-space: nowrap; }
.step-card { display: inline-grid; vertical-align: top; width: 210rpx; min-height: 92rpx; box-sizing: border-box; margin-right: 10rpx; padding: 12rpx; border-radius: 18rpx; background: #edf5ff; }
.step-card.stair { background: #fff1d5; }
.step-card.target { background: #ffe9e6; }
.step-no,
.step-title,
.step-desc { display: block; }
.step-no { color: #0b6cff; font-size: 17rpx; font-weight: 950; }
.step-title { margin-top: 4rpx; color: #17253a; font-size: 20rpx; font-weight: 950; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.step-desc { margin-top: 4rpx; color: #657a92; font-size: 16rpx; font-weight: 800; line-height: 1.22; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

.quick-row,
.layer-grid { display: flex; flex-wrap: wrap; gap: 10rpx; }
.quick-row button,
.layer-grid button { min-width: 108rpx; height: 48rpx; padding: 0 16rpx; color: #075bd4; font-size: 18rpx; font-weight: 950; line-height: 48rpx; border-radius: 999rpx; background: #e5f0ff; }
.quick-row button.plain { color: #61758d; background: #eef2f6; }
.layer-grid button.active { color: #ffffff; background: #0b6cff; }
.detail-title { display: block; color: #17253a; font-size: 24rpx; font-weight: 950; }
.detail-desc { display: block; margin-top: 8rpx; color: #61758d; font-size: 19rpx; font-weight: 820; line-height: 1.35; }
.panel-note { color: #6b7d93; font-size: 17rpx; font-weight: 820; line-height: 1.25; }

@media (max-width: 700px) and (orientation: landscape) {
  .floor-deck { left: 51%; top: 56%; width: 78vw; height: 54vh; }
  .layer-all .floor-deck { transform: translate(calc(-50% + (var(--floor-index) * 22rpx)), calc(-50% - (var(--floor-index) * 50rpx))) rotateX(53deg) rotateZ(-10deg) scale(0.8); }
  .layer-1F .floor-deck,
  .layer-2F .floor-deck,
  .layer-25F .floor-deck { width: 82vw; height: 60vh; transform: translate(-50%, -50%) rotateX(48deg) rotateZ(-7deg) scale(0.9); }
  .material-panel { width: min(560rpx, 62vw); }
  .map3d-guidance-strip { max-width: 560rpx; }
  .room-name,
  .corridor text,
  .stair text { display: none; }
}
