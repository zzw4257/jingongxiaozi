page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #edf5ff;
}

.native-map-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  color: #17253a;
  background:
    radial-gradient(circle at 42% 52%, rgba(80, 132, 196, 0.17), transparent 36%),
    radial-gradient(circle at 70% 40%, rgba(255, 170, 66, 0.08), transparent 34%),
    linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
}

.map-backplate {
  position: absolute;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(circle at 46% 48%, rgba(80, 132, 196, 0.16), transparent 38%),
    linear-gradient(180deg, #f8fbff 0%, #edf5ff 100%);
}

.map-stage {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  overflow: hidden;
}

.map-canvas {
  position: absolute;
  left: 6px;
  top: 6px;
  z-index: 8;
  display: block;
  width: calc(100% - 12px);
  height: calc(100% - 12px);
  opacity: 1;
  pointer-events: auto;
  border-radius: 20px;
  touch-action: none;
}

.native-map-hit-layer {
  position: absolute;
  left: 6px;
  top: 6px;
  right: 6px;
  bottom: 6px;
  z-index: 12;
  overflow: hidden;
  background: transparent;
  border-radius: 20px;
  border: 1px solid rgba(166, 191, 218, 0.34);
  box-shadow: none;
  pointer-events: auto;
}

.native-floor,
.native-space,
.native-room,
.native-stair,
.native-door,
.native-route-segment,
.native-route-pin {
  position: absolute;
  box-sizing: border-box;
}

.native-floor {
  z-index: 1;
  border: 2px solid rgba(42, 65, 88, 0.34);
  border-radius: 10px;
  background: rgba(248, 252, 255, 0.68);
  box-shadow: 0 18px 34px rgba(28, 62, 98, 0.14);
}

.native-floor-2F {
  background: rgba(233, 245, 255, 0.68);
}

.native-floor-25F {
  background: rgba(255, 231, 184, 0.72);
  border-color: rgba(152, 88, 0, 0.4);
  box-shadow: 0 14px 28px rgba(152, 88, 0, 0.14);
}

.native-floor-title {
  position: absolute;
  left: 7px;
  top: 6px;
  color: #17324f;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 999px;
  padding: 2px 8px;
  font-size: 11px;
  font-weight: 950;
  line-height: 16px;
}

.native-space {
  z-index: 3;
  border: 1.5px solid rgba(32, 106, 143, 0.18);
  border-radius: 5px;
  background: rgba(126, 222, 255, 0.12);
}

.native-space-corridor {
  background: rgba(212, 242, 255, 0.82);
  border-color: rgba(67, 142, 178, 0.48);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.46);
}

.native-space-restroom,
.native-space-service {
  background: rgba(145, 229, 184, 0.78);
  border-color: rgba(56, 137, 92, 0.72);
}

.native-space-storage,
.native-space-reserved {
  background: rgba(195, 209, 224, 0.78);
  border-color: rgba(105, 126, 148, 0.7);
}

.native-space-label {
  position: absolute;
  left: 4px;
  top: 3px;
  color: rgba(23, 81, 110, 0.84);
  font-size: 9px;
  font-weight: 900;
  line-height: 11px;
}

.native-room {
  z-index: 5;
  display: grid;
  place-items: center;
  border: 1.5px solid rgba(47, 68, 90, 0.58);
  border-radius: 5px;
  background: rgba(255, 245, 226, 0.74);
  box-shadow: 0 4px 10px rgba(20, 53, 94, 0.08);
  opacity: 1;
  pointer-events: auto;
}

.native-shell-ui {
  opacity: 1;
  pointer-events: auto;
}

.native-room-teaching,
.native-room-processing,
.native-room-lab,
.native-room-office,
.native-room-service,
.native-room-other {
  background: rgba(255, 245, 226, 0.74);
}
.native-room-teaching { background: rgba(219, 234, 254, 0.82); }
.native-room-processing { background: rgba(255, 220, 168, 0.86); }
.native-room-lab { background: rgba(255, 240, 189, 0.84); }
.native-room-office { background: rgba(216, 196, 255, 0.82); }
.native-room-service { background: rgba(223, 245, 232, 0.82); }
.native-room-other { background: rgba(238, 242, 246, 0.82); }
.native-room-on-route {
  border-color: #0b6cff;
  box-shadow: 0 0 0 4px rgba(11, 108, 255, 0.16), 0 8px 18px rgba(20, 53, 94, 0.12);
}

.native-room-label {
  max-width: 92%;
  padding: 1px 5px;
  color: #17253a;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999px;
  font-size: 10px;
  font-weight: 950;
  line-height: 13px;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.native-stair {
  z-index: 7;
  display: grid;
  place-items: center;
  border: 2px solid rgba(141, 79, 0, 0.72);
  border-radius: 4px;
  background:
    repeating-linear-gradient(90deg, rgba(111, 62, 0, 0.72) 0, rgba(111, 62, 0, 0.72) 1px, transparent 1px, transparent 6px),
    linear-gradient(135deg, rgba(255, 255, 255, 0.32), transparent 52%),
    rgba(255, 176, 46, 0.78);
  box-shadow: 0 7px 16px rgba(152, 88, 0, 0.12);
}

.native-stair-on-route {
  box-shadow: 0 0 0 4px rgba(255, 151, 0, 0.24);
}

.native-stair-label {
  color: rgba(98, 56, 0, 0);
  background: rgba(255, 255, 255, 0);
  border-radius: 999px;
  padding: 1px 5px;
  font-size: 9px;
  font-weight: 950;
}

.native-door {
  z-index: 9;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.82);
  border: 1.5px solid rgba(27, 46, 68, 0.34);
  box-shadow: 0 3px 8px rgba(20, 53, 94, 0.12);
}

.native-door-on-route {
  background: #0b6cff;
  border-color: #0b6cff;
}

.native-route-segment {
  z-index: 12;
  height: 7px;
  transform-origin: left center;
  border-radius: 999px;
  background: #0b6cff;
  box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.9), 0 7px 16px rgba(6, 48, 112, 0.28);
}

.native-route-segment-stair {
  background: #ff9700;
}

.native-route-segment-active {
  height: 9px;
  box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.92), 0 8px 18px rgba(6, 48, 112, 0.32);
}

.native-route-pin {
  z-index: 14;
  display: grid;
  place-items: center;
  width: 30px;
  height: 30px;
  margin-left: -15px;
  margin-top: -15px;
  color: #ffffff;
  border: 2px solid #ffffff;
  border-radius: 50%;
  background: #0b6cff;
  box-shadow: 0 10px 22px rgba(6, 48, 112, 0.28);
}

.native-route-pin-start { background: #16a060; }
.native-route-pin-target { background: #ff3f6c; }
.native-route-pin-next { background: #0b6cff; }

.native-route-pin text {
  font-size: 10px;
  font-weight: 950;
  line-height: 1;
}

.map-ambient {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.map-ambient-a {
  left: 12vw;
  top: 6vh;
  width: 42vw;
  height: 42vw;
  background: radial-gradient(circle, rgba(11, 108, 255, 0.12), transparent 64%);
}

.map-ambient-b {
  right: 10vw;
  bottom: 4vh;
  width: 34vw;
  height: 34vw;
  background: radial-gradient(circle, rgba(255, 154, 0, 0.12), transparent 62%);
}

.map-compass {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  z-index: 20;
  display: inline-grid;
  grid-template-columns: 42rpx auto;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 7rpx 14rpx 7rpx 7rpx;
  color: #17324f;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(188, 210, 232, 0.9);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 53, 94, 0.14);
  font-size: 18rpx;
  font-weight: 950;
}

.north-arrow {
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: #17253a;
  border-radius: 50%;
}

.compass-copy view {
  display: block;
  line-height: 1.12;
}

.compass-copy view + view {
  margin-top: 3rpx;
  color: #687a90;
  font-size: 13rpx;
  font-weight: 850;
}

.map-legend {
  position: absolute;
  left: 18rpx;
  top: 82rpx;
  z-index: 20;
  display: none;
  gap: 9rpx;
  padding: 8rpx 12rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(201, 218, 238, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.1);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
  color: #5b7088;
  font-size: 15rpx;
  font-weight: 900;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 5rpx;
}

.legend-dot.corridor { background: #d9f2ff; border: 2rpx solid #7bb9d6; }
.legend-dot.room { background: #fff0d7; border: 2rpx solid #53677f; }
.legend-dot.stair { background: #ffc25b; border: 2rpx solid #b66b00; }
.legend-dot.route { background: #0b6cff; border-radius: 999rpx; }

.layer-status-pill {
  position: absolute;
  left: 18rpx;
  top: 134rpx;
  z-index: 22;
  display: none;
  max-width: 560rpx;
  padding: 9rpx 15rpx;
  color: #1a3551;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(201, 218, 238, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.11);
}

.layer-status-pill view {
  display: inline;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1.1;
}

.layer-status-pill view + view {
  margin-left: 12rpx;
  color: #657990;
  font-size: 15rpx;
  font-weight: 850;
}

.map3d-bottom-chip {
  position: absolute;
  left: 14rpx;
  bottom: 14rpx;
  z-index: 18;
  display: grid;
  grid-template-columns: 50rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  max-width: min(560rpx, calc(100vw - 170rpx));
  min-height: 56rpx;
  padding: 8rpx 14rpx 8rpx 9rpx;
  color: #20344f;
  background: rgba(255, 255, 255, 0.93);
  border: 2rpx solid rgba(207, 222, 241, 0.94);
  border-radius: 26rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 53, 94, 0.12);
}

.map3d-bottom-chip image {
  width: 48rpx;
  height: 48rpx;
}

.map3d-bottom-chip view view {
  display: block;
  overflow: hidden;
  font-size: 18rpx;
  font-weight: 950;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map3d-bottom-chip view view + view {
  color: #5e7189;
  font-size: 14rpx;
  font-weight: 850;
}

.map3d-guidance-strip {
  position: absolute;
  left: 14px;
  right: 74px;
  bottom: 12px;
  z-index: 72;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto minmax(0, 1.08fr) auto auto;
  align-items: center;
  gap: 8px;
  box-sizing: border-box;
  min-height: 58px;
  padding: 8px 10px;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(15, 28, 44, 0.9), rgba(7, 65, 135, 0.88));
  backdrop-filter: blur(8px);
  border: 1px solid rgba(146, 202, 255, 0.42);
  border-radius: 20px;
  box-shadow: 0 18px 38px rgba(6, 24, 56, 0.28);
}

.guidance-hot-action {
  position: absolute;
  top: 8px;
  bottom: 8px;
  border-radius: 999px;
}

.guidance-hot-focus {
  right: 70px;
  width: 58px;
}

.guidance-hot-next {
  right: 10px;
  width: 58px;
}

.guidance-strip-actions {
  display: flex;
  gap: 6px;
}

.guidance-action {
  display: grid;
  place-items: center;
  min-width: 48px;
  min-height: 36px;
  padding: 0 10px;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 950;
  line-height: 36px;
}

.guidance-action.primary {
  color: #0d2a45;
  background: #ffffff;
}

.guidance-action.secondary {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
}

.guidance-strip-step {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  color: #ffffff;
  background: #1ac46d;
  border-radius: 50%;
  font-size: 13px;
  font-weight: 950;
}

.guidance-strip-node {
  min-width: 0;
}

.guidance-strip-node view {
  display: block;
  overflow: hidden;
  color: rgba(226, 238, 255, 0.74);
  font-size: 11px;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guidance-strip-node .guidance-strong {
  color: #ffffff;
  font-size: 15px;
  font-weight: 950;
}

.guidance-strip-node.next .guidance-strong {
  color: #bfe0ff;
}

.guidance-arrow {
  color: rgba(255, 255, 255, 0.6);
  font-size: 18px;
  font-weight: 950;
}

.guidance-strip-distance {
  display: grid;
  place-items: center;
  min-width: 48px;
  min-height: 32px;
  padding: 0 10px;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 950;
}

.map-rail {
  position: absolute;
  right: 9px;
  top: 50%;
  z-index: 240;
  width: 40px;
  height: 178px;
  transform: translateY(-50%);
  border-radius: 999px;
}

.map3d-guidance-strip.native-hot-guidance .guidance-hot-action {
  color: transparent;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}

.rail-button {
  position: absolute;
  right: 5px;
  display: grid;
  place-items: center;
  width: 30px;
  height: 25px;
  padding: 0;
  color: #20344f;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(194, 211, 232, 0.92);
  border-radius: 999px;
  box-shadow: 0 8px 18px rgba(20, 53, 94, 0.13);
  font-size: 12px;
  font-weight: 950;
  line-height: 1;
}

.rail-icon {
  font-size: 20px;
  line-height: 1;
}

.rail-button.active {
  color: #ffffff;
  background: #0b6cff;
}

.map-rail.native-hot-rail .rail-hot-button,
.map-rail.native-hot-rail .rail-hot-button.active {
  pointer-events: auto;
}

.map-rail.native-hot-rail .rail-hot-button.active {
  color: #ffffff;
  background: #0b6cff;
  border-color: #0b6cff;
  box-shadow: 0 12px 24px rgba(11, 108, 255, 0.24);
}

.rail-visible-icon {
  display: block;
  color: currentColor;
  opacity: 1;
  font-size: 15px;
  font-weight: 950;
  line-height: 1;
}

.map-rail.native-hot-rail {
  background: rgba(255, 255, 255, 0.42);
  border: 1px solid rgba(194, 211, 232, 0.76);
  box-shadow: 0 14px 30px rgba(20, 53, 94, 0.12);
  backdrop-filter: blur(12px);
  pointer-events: auto;
}

.map-rail.native-hot-rail .rail-hot-button:nth-child(1) { top: 4px; }
.map-rail.native-hot-rail .rail-hot-button:nth-child(2) { top: 40px; }
.map-rail.native-hot-rail .rail-hot-button:nth-child(3) { top: 76px; }
.map-rail.native-hot-rail .rail-hot-button:nth-child(4) { top: 112px; }
.map-rail.native-hot-rail .rail-hot-button:nth-child(5) { top: 148px; }

.panel-shade {
  position: absolute;
  inset: 0 58px 0 0;
  z-index: 38;
  background: rgba(16, 31, 55, 0.14);
  backdrop-filter: blur(2rpx);
}

.material-panel {
  position: absolute;
  right: 58px;
  top: 12px;
  z-index: 40;
  width: min(344px, calc(100vw - 76px));
  height: min(240px, calc(100vh - 24px));
  box-sizing: border-box;
  padding: 12px;
  overflow: hidden;
  background: #ffffff;
  border: 1px solid rgba(201, 218, 238, 0.96);
  border-radius: 22px;
  box-shadow: 0 22px 58px rgba(20, 53, 94, 0.26);
}

.material-panel.panel-route {
  top: 12px;
  right: 58px;
  width: min(344px, calc(100vw - 76px));
  height: auto;
  max-height: min(240px, calc(100vh - 24px));
}

.panel-card {
  display: grid;
  gap: 10rpx;
}

.panel-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  align-items: center;
  gap: 14rpx;
}

.panel-title {
  color: #17253a;
  font-size: 25rpx;
  font-weight: 950;
}

.panel-meta {
  color: #0b6cff;
  font-size: 20rpx;
  font-weight: 950;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  color: #405875;
  background: #eef4fb;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 44rpx;
}

.route-summary,
.room-detail {
  color: #566a82;
  font-size: 20rpx;
  font-weight: 850;
}

.route-summary {
  display: grid;
  gap: 10rpx;
}

.muted {
  color: #7b8da3;
}

.route-mode-banner {
  display: grid;
  grid-template-columns: 42rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  min-height: 58rpx;
  padding: 9rpx 12rpx;
  color: #20344f;
  background: linear-gradient(180deg, #ffffff 0%, #edf6ff 100%);
  border: 2rpx solid #cfe0f4;
  border-radius: 22rpx;
}

.route-mode-icon {
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: #0b6cff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 950;
}

.route-mode-banner view view:first-child {
  display: block;
  color: #17253a;
  font-size: 19rpx;
  font-weight: 950;
}

.route-mode-banner view view + view {
  display: block;
  overflow: hidden;
  color: #61758d;
  font-size: 14rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.step-strip {
  width: 100%;
  white-space: nowrap;
}

.route-step-window {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.step-card {
  display: grid;
  min-width: 0;
  min-height: 92rpx;
  box-sizing: border-box;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #edf5ff;
}

.step-card.stair {
  background: #fff1d5;
}

.step-card.target {
  background: #ffe9e6;
}

.step-no,
.step-title,
.step-desc {
  display: block;
}

.step-no {
  color: #0b6cff;
  font-size: 17rpx;
  font-weight: 950;
}

.step-title {
  margin-top: 4rpx;
  color: #17253a;
  font-size: 20rpx;
  font-weight: 950;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.step-desc {
  margin-top: 4rpx;
  color: #657a92;
  font-size: 16rpx;
  font-weight: 800;
  line-height: 1.22;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.quick-row,
.layer-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.quick-row button,
.layer-grid button {
  min-width: 108rpx;
  height: 48rpx;
  padding: 0 16rpx;
  color: #075bd4;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.quick-row button.plain {
  color: #61758d;
  background: #eef2f6;
}

.layer-grid button.active {
  color: #ffffff;
  background: #0b6cff;
}

.route-nav-sheet {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 8rpx;
  min-height: 62rpx;
  padding: 8rpx 10rpx;
  color: #20344f;
  background: linear-gradient(180deg, #ffffff 0%, #f3f8ff 100%);
  border: 2rpx solid #cfe0f4;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.09);
}

.route-nav-sheet.active {
  border-color: #a9cdfc;
  box-shadow: 0 14rpx 30rpx rgba(11, 108, 255, 0.12);
}

.route-nav-endpoint {
  display: grid;
  grid-template-columns: 32rpx minmax(0, 1fr);
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.route-nav-endpoint > view:first-child {
  display: grid;
  place-items: center;
  width: 32rpx;
  height: 32rpx;
  color: #ffffff;
  background: #18a058;
  border-radius: 50%;
  font-size: 14rpx;
  font-weight: 950;
}

.route-nav-endpoint.target > view:first-child {
  background: #ff3f6c;
}

.route-endpoint-title,
.guidance-node-title,
.tile-title {
  display: block;
  overflow: hidden;
  color: #17253a;
  font-size: 18rpx;
  font-weight: 950;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-nav-meta,
.route-nav-arrow {
  color: #5f728b;
  font-size: 14rpx;
  font-weight: 900;
  white-space: nowrap;
}

.route-nav-arrow {
  color: #0b6cff;
}

.route-guidance-card {
  display: grid;
  grid-template-columns: auto minmax(0, 0.9fr) auto minmax(0, 1.25fr);
  align-items: center;
  gap: 8rpx;
  padding: 10rpx;
  color: #17253a;
  background: #eaf4ff;
  border: 2rpx solid #9ec8ff;
  border-radius: 20rpx;
  box-shadow: inset 0 0 0 1rpx rgba(11, 108, 255, 0.12);
}

.route-guidance-card view {
  min-width: 0;
}

.guidance-node-label,
.guidance-node-hint,
.tile-subtitle,
.tile-caption {
  display: block;
  overflow: hidden;
  color: #647891;
  font-size: 13rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guidance-node-hint {
  color: #0b6cff;
}

.route-guidance-progress {
  display: grid;
  place-items: center;
  width: 40rpx;
  height: 40rpx;
  color: #ffffff;
  background: #0b6cff;
  border-radius: 50%;
  font-size: 13rpx;
  font-weight: 950;
}

.route-target-shortcuts,
.layer-mode-stack,
.view-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.material-panel.panel-route .route-step-window {
  display: none;
}

.material-panel.panel-route .route-target-shortcuts {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.route-target-shortcuts-quick {
  align-items: stretch;
}

.material-panel.panel-route .tile-button {
  min-height: 56rpx;
}

.layer-mode-stack {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.tile-button {
  display: grid;
  align-content: center;
  gap: 4rpx;
  min-width: 0;
  min-height: 62rpx;
  padding: 8rpx 10rpx;
  color: #20344f;
  background: #f8fbff;
  border: 2rpx solid #d8e4f3;
  border-radius: 19rpx;
  text-align: left;
}

.primary-layer {
  grid-column: span 2;
  background: linear-gradient(180deg, #ffffff 0%, #edf6ff 100%);
}

.route-action-controls,
.route-secondary-row,
.view-control-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.view-control-row {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.action-button,
.material-primary,
.material-secondary {
  display: grid;
  place-items: center;
  min-height: 52rpx;
  padding: 0 12rpx;
  border-radius: 18rpx;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 52rpx;
}

.material-primary {
  color: #ffffff;
  background: #0b6cff;
}

.material-secondary {
  color: #31516f;
  background: #edf4fb;
}

.disabled {
  opacity: 0.42;
}

.tile-button.active {
  color: #ffffff;
  background: #0b6cff;
  border-color: #0b6cff;
}

.tile-button.plain {
  align-items: center;
  justify-items: center;
  color: #61758d;
  background: #eef2f6;
}

.tile-button.active .tile-title,
.tile-button.active .tile-subtitle,
.tile-button.active .tile-caption {
  color: #ffffff;
}

.detail-title {
  display: block;
  color: #17253a;
  font-size: 24rpx;
  font-weight: 950;
}

.detail-desc {
  display: block;
  margin-top: 8rpx;
  color: #61758d;
  font-size: 19rpx;
  font-weight: 820;
  line-height: 1.35;
}

.start-route-button {
  width: 180rpx;
  height: 52rpx;
  margin: 12rpx 0 0;
  color: #ffffff;
  background: #0b6cff;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 52rpx;
}

.panel-note {
  color: #6b7d93;
  font-size: 17rpx;
  font-weight: 820;
  line-height: 1.25;
}

/* Kept as verification anchors for the native canvas renderer. */
.floor-deck,
.space-corridor,
.room,
.door,
.route-segment,
.stair,
.route-node {
  box-sizing: border-box;
}

@media (orientation: landscape) {
  .map-stage {
    right: 0;
    bottom: 0;
  }

  .map-rail {
    right: 9px;
    top: 50%;
    bottom: auto;
    width: 40px;
    height: 178px;
    transform: translateY(-50%);
  }

  .rail-button {
    right: 5px;
    width: 30px;
    height: 25px;
    border-width: 1px;
    border-radius: 999px;
    font-size: 11px;
    line-height: 1;
  }

  .rail-icon {
    font-size: 17px;
  }

  .material-panel {
    right: 58px;
    top: 8px;
    width: min(282px, calc(100vw - 74px));
    height: min(176px, calc(100vh - 16px));
    padding: 8px;
    border-width: 1px;
    border-radius: 18px;
  }

  .material-panel.panel-route {
    right: 58px;
    width: min(282px, calc(100vw - 74px));
    max-height: min(176px, calc(100vh - 16px));
  }

  .material-panel.panel-route .route-nav-sheet,
  .material-panel.panel-route .route-guidance-card,
  .material-panel.panel-route .route-action-controls {
    display: none;
  }

  .material-panel.panel-route .route-mode-banner {
    grid-template-columns: 34rpx minmax(0, 1fr);
    min-height: 48rpx;
    padding: 7rpx 9rpx;
    border-radius: 18rpx;
  }

  .material-panel.panel-route .route-mode-icon {
    width: 34rpx;
    height: 34rpx;
    font-size: 18rpx;
  }

  .route-mode-banner view view:first-child {
    font-size: 16rpx;
  }

  .route-mode-banner view view + view {
    font-size: 12rpx;
  }

  .material-panel.panel-route .route-target-shortcuts {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .map3d-guidance-strip {
    left: 10px;
    right: 56px;
    bottom: 8px;
    grid-template-columns: auto minmax(0, 0.86fr) auto minmax(0, 1fr);
    grid-template-rows: auto auto;
    min-height: 48px;
    padding: 6px 8px;
    gap: 4px 6px;
    border-radius: 18px;
  }

  .guidance-strip-step {
    width: 30px;
    height: 30px;
    font-size: 10px;
  }

  .guidance-strip-node view {
    font-size: 10px;
  }

  .guidance-strip-node .guidance-strong {
    font-size: 12px;
  }

  .guidance-action {
    min-width: 40px;
    min-height: 26px;
    padding: 0 8px;
    font-size: 11px;
    line-height: 26px;
  }

  .guidance-strip-actions {
    grid-column: 5 / 7;
    grid-row: 2;
    justify-self: end;
  }

  .map-legend {
    display: none;
  }

  .panel-title {
    font-size: 16px;
  }

  .panel-meta {
    font-size: 12px;
  }

  .route-target-shortcuts,
  .view-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 5px;
  }

  .route-secondary-row {
    display: none;
  }

  .layer-mode-stack {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 5px;
  }

  .primary-layer {
    grid-column: span 1;
  }

  .tile-button {
    min-height: 38px;
    padding: 5px 6px;
    border-width: 1px;
    border-radius: 12px;
  }

  .tile-title,
  .route-endpoint-title,
  .guidance-node-title {
    font-size: 12px;
  }

  .tile-subtitle,
  .tile-caption,
  .guidance-node-label,
  .guidance-node-hint {
    font-size: 9px;
  }

  .step-card {
    min-height: 56px;
    padding: 7px;
  }

  .panel-note {
    display: none;
  }

  .map-compass {
    left: 8px;
    top: 8px;
    min-height: 34px;
    padding: 4px 10px 4px 4px;
    border-width: 1px;
    transform: none;
    transform-origin: left top;
  }

  .north-arrow {
    width: 30px;
    height: 30px;
  }

  .compass-copy view {
    font-size: 11px;
  }

  .compass-copy view + view {
    font-size: 9px;
  }

  .native-map-visual {
    left: 6px;
    top: 6px;
    right: 6px;
    bottom: 6px;
    border-radius: 18px;
  }

  .layer-1F .native-map-visual,
  .layer-2F .native-map-visual,
  .layer-raised202 .native-map-visual {
    bottom: 6px;
  }

  .layer-1F .native-room-label,
  .layer-2F .native-room-label,
  .layer-raised202 .native-room-label {
    font-size: 11px;
    line-height: 14px;
  }

  .layer-allFloors .native-room-label,
  .layer-exploded .native-room-label,
  .layer-section .native-room-label {
    font-size: 9px;
    line-height: 12px;
    padding: 1px 4px;
  }
}


@media (max-width: 700px) and (orientation: landscape) {
  .map-stage {
    right: 0;
    bottom: 0;
  }

  .map-rail {
    right: 9px;
    top: 50%;
    bottom: auto;
    width: 40px;
    height: 178px;
    transform: translateY(-50%);
  }

  .rail-button {
    right: 5px;
    width: 30px;
    height: 25px;
    border-radius: 999px;
    font-size: 11px;
  }

  .rail-icon {
    font-size: 17px;
  }

  .material-panel,
  .material-panel.panel-route {
    right: 58px;
    width: min(262px, calc(100vw - 74px));
  }

  .map3d-guidance-strip {
    left: 8px;
    right: 56px;
    bottom: 6px;
  }

  .map3d-guidance-strip {
    grid-template-columns: auto minmax(0, 0.86fr) auto minmax(0, 1fr);
    grid-template-rows: auto auto;
    min-height: 50px;
    padding: 6px 7px;
    gap: 4px 5px;
  }

  .guidance-strip-distance {
    display: none;
  }

  .guidance-strip-actions {
    grid-column: 4;
  }

  .native-map-visual {
    left: 5px;
    top: 5px;
    right: 5px;
    bottom: 5px;
  }
}
