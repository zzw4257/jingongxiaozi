page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #edf5fb;
}

.native-map-page {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 12%, rgba(11, 108, 255, 0.12), transparent 30%),
    linear-gradient(145deg, #f8fbff, #eaf2fb);
}

.map-topbar {
  position: fixed;
  left: 24rpx;
  top: 18rpx;
  right: 172rpx;
  z-index: 50;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  pointer-events: none;
}

.map-title,
.map-subtitle {
  display: block;
}

.map-title {
  color: #162640;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.1;
}

.map-subtitle {
  margin-top: 6rpx;
  color: #637990;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
}

.north-chip {
  padding: 10rpx 16rpx;
  color: #075bd4;
  font-size: 20rpx;
  font-weight: 950;
  border-radius: 999rpx;
  background: rgba(229, 240, 255, 0.9);
}

.map-scene {
  position: absolute;
  left: 4vw;
  right: 146rpx;
  top: 74rpx;
  bottom: 218rpx;
  perspective: 1100rpx;
}

.floor-deck {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 82vw;
  max-width: 1050rpx;
  height: 58vh;
  max-height: 520rpx;
  transform-origin: center;
}

.layer-all .floor-deck {
  transform: translate(-50%, -50%) rotateX(58deg) rotateZ(-16deg);
}

.layer-1F .floor-deck,
.layer-2F .floor-deck,
.layer-25F .floor-deck {
  transform: translate(-50%, -50%) rotateX(50deg) rotateZ(-10deg) scale(1.12);
}

.floor-slab {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  border: 3rpx solid #7c8ea4;
  border-radius: 22rpx;
  background: #f7fbff;
  box-shadow:
    0 18rpx 0 #c7d8ea,
    0 34rpx 58rpx rgba(20, 53, 94, 0.18);
}

.floor-2F .floor-slab {
  background: #f4f8ff;
  border-color: #6e86a2;
}

.floor-25F .floor-slab {
  background: #fff8ed;
  border-color: #d18d2d;
}

.floor-title {
  position: absolute;
  left: 18rpx;
  top: 16rpx;
  z-index: 4;
  padding: 8rpx 14rpx;
  color: #17253a;
  font-size: 18rpx;
  font-weight: 950;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(20, 53, 94, 0.12);
}

.corridor,
.room {
  position: absolute;
  z-index: 5;
  box-sizing: border-box;
}

.corridor {
  display: grid;
  place-items: center;
  color: #0b5ecf;
  font-size: 16rpx;
  font-weight: 950;
  border: 2rpx dashed rgba(11, 108, 255, 0.36);
  border-radius: 14rpx;
  background: rgba(204, 229, 255, 0.76);
}

.room {
  display: grid;
  align-content: center;
  justify-items: center;
  gap: 3rpx;
  padding: 6rpx;
  border: 3rpx solid rgba(77, 102, 132, 0.72);
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: inset 0 -7rpx 0 rgba(69, 89, 112, 0.08);
}

.area-workshop {
  background: #fff0d8;
  border-color: #c7781e;
}

.area-public {
  background: #e7f2ff;
  border-color: #2d7eea;
}

.area-service {
  background: #e8f7f0;
  border-color: #23a26d;
}

.area-utility {
  background: #eef1f5;
  border-color: #8a98aa;
}

.area-mezzanine {
  background: #ffe9c5;
  border-color: #d18d2d;
}

.area-stair {
  background: #fff3dc;
  border-color: #e69a25;
}

.room.active {
  border-color: #0b6cff;
  box-shadow: 0 0 0 5rpx rgba(11, 108, 255, 0.2), inset 0 -7rpx 0 rgba(69, 89, 112, 0.08);
}

.room-no {
  color: #17253a;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 1.05;
}

.room-name {
  max-width: 100%;
  color: #586d84;
  font-size: 13rpx;
  font-weight: 850;
  line-height: 1.1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.stair,
.route-node {
  position: absolute;
  z-index: 12;
  transform: translate(-50%, -50%);
}

.stair {
  width: 74rpx;
  height: 54rpx;
  display: grid;
  place-items: center;
  border-radius: 14rpx;
  background: #ffe0a7;
  border: 3rpx solid #dc8a17;
  box-shadow: 0 12rpx 20rpx rgba(130, 77, 0, 0.2);
}

.stair.active {
  background: #ffb12b;
  border-color: #c76700;
}

.stair text {
  position: absolute;
  left: 50%;
  top: -26rpx;
  width: 132rpx;
  transform: translateX(-50%);
  color: #7a4300;
  font-size: 15rpx;
  font-weight: 950;
  text-align: center;
}

.stair-treads {
  display: grid;
  gap: 4rpx;
  width: 46rpx;
}

.stair-treads text {
  display: block;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(101, 57, 0, 0.72);
}

.route-node {
  width: 38rpx;
  height: 38rpx;
  display: grid;
  place-items: center;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 950;
  border-radius: 999rpx;
  background: #0b6cff;
  box-shadow: 0 0 0 8rpx rgba(11, 108, 255, 0.18), 0 12rpx 28rpx rgba(11, 108, 255, 0.26);
}

.route-node.stair-node {
  background: #ff9a00;
  box-shadow: 0 0 0 8rpx rgba(255, 154, 0, 0.2), 0 12rpx 28rpx rgba(180, 93, 0, 0.26);
}

.route-node.current {
  width: 46rpx;
  height: 46rpx;
  background: #00a36c;
}

.route-node.target {
  width: 50rpx;
  height: 50rpx;
  background: #f04438;
}

.map-rail {
  position: fixed;
  right: 18rpx;
  top: 50%;
  z-index: 80;
  display: grid;
  gap: 12rpx;
  transform: translateY(-50%);
}

.map-rail button {
  width: 104rpx;
  height: 68rpx;
  padding: 0;
  color: #233855;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 68rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 26rpx rgba(22, 45, 78, 0.14);
}

.map-rail button::after,
.quick-row button::after,
.layer-grid button::after {
  display: none;
}

.map-rail button.active {
  color: #ffffff;
  background: #0b6cff;
}

.bottom-panel {
  position: fixed;
  left: 20rpx;
  right: 146rpx;
  bottom: 16rpx;
  z-index: 70;
}

.panel-card {
  box-sizing: border-box;
  min-height: 174rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(207, 226, 255, 0.96);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 52rpx rgba(22, 45, 78, 0.18);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-title {
  color: #17253a;
  font-size: 26rpx;
  font-weight: 950;
}

.panel-meta {
  color: #0b6cff;
  font-size: 20rpx;
  font-weight: 950;
}

.route-summary,
.room-detail {
  margin-top: 10rpx;
  color: #566a82;
  font-size: 20rpx;
  font-weight: 850;
}

.muted {
  color: #7b8da3;
}

.step-strip {
  margin-top: 12rpx;
  width: 100%;
  white-space: nowrap;
}

.step-card {
  display: inline-grid;
  vertical-align: top;
  width: 220rpx;
  min-height: 96rpx;
  box-sizing: border-box;
  margin-right: 12rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #edf5ff;
}

.step-card.stair {
  background: #fff1d5;
}

.step-card.target {
  background: #ffe9e6;
}

.step-no,
.step-title,
.step-desc {
  display: block;
}

.step-no {
  color: #0b6cff;
  font-size: 18rpx;
  font-weight: 950;
}

.step-title {
  margin-top: 4rpx;
  color: #17253a;
  font-size: 21rpx;
  font-weight: 950;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.step-desc {
  margin-top: 4rpx;
  color: #657a92;
  font-size: 17rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.quick-row,
.layer-grid {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.quick-row button,
.layer-grid button {
  min-width: 112rpx;
  height: 48rpx;
  padding: 0 16rpx;
  color: #075bd4;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.quick-row button.plain {
  color: #61758d;
  background: #eef2f6;
}

.layer-grid button.active {
  color: #ffffff;
  background: #0b6cff;
}

.detail-title {
  display: block;
  color: #17253a;
  font-size: 24rpx;
  font-weight: 950;
}

.detail-desc {
  display: block;
  margin-top: 8rpx;
  color: #61758d;
  font-size: 20rpx;
  font-weight: 820;
  line-height: 1.35;
}
