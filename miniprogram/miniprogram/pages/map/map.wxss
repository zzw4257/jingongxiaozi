page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #edf5ff;
}

.native-map-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  color: #17253a;
  background:
    radial-gradient(circle at 46% 48%, rgba(80, 132, 196, 0.16), transparent 38%),
    linear-gradient(180deg, #f8fbff 0%, #edf5ff 100%);
}

.map-stage {
  position: absolute;
  left: 0;
  top: 0;
  right: 104rpx;
  bottom: 0;
  overflow: hidden;
}

.map-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  touch-action: none;
}

.map-ambient {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.map-ambient-a {
  left: 12vw;
  top: 6vh;
  width: 42vw;
  height: 42vw;
  background: radial-gradient(circle, rgba(11, 108, 255, 0.12), transparent 64%);
}

.map-ambient-b {
  right: 10vw;
  bottom: 4vh;
  width: 34vw;
  height: 34vw;
  background: radial-gradient(circle, rgba(255, 154, 0, 0.12), transparent 62%);
}

.map-compass {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  z-index: 20;
  display: inline-grid;
  grid-template-columns: 42rpx auto;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 7rpx 14rpx 7rpx 7rpx;
  color: #17324f;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(188, 210, 232, 0.9);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 53, 94, 0.14);
  font-size: 18rpx;
  font-weight: 950;
}

.north-arrow {
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: #17253a;
  border-radius: 50%;
}

.map-compass text {
  display: block;
  line-height: 1.12;
}

.map-compass text + text {
  margin-top: 3rpx;
  color: #687a90;
  font-size: 13rpx;
  font-weight: 850;
}

.map-legend {
  position: absolute;
  left: 18rpx;
  top: 82rpx;
  z-index: 20;
  display: flex;
  gap: 9rpx;
  padding: 8rpx 12rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(201, 218, 238, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.1);
}

.map-legend view {
  display: flex;
  align-items: center;
  gap: 5rpx;
  color: #5b7088;
  font-size: 15rpx;
  font-weight: 900;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 5rpx;
}

.legend-dot.corridor { background: #d9f2ff; border: 2rpx solid #7bb9d6; }
.legend-dot.room { background: #fff0d7; border: 2rpx solid #53677f; }
.legend-dot.stair { background: #ffc25b; border: 2rpx solid #b66b00; }
.legend-dot.route { background: #0b6cff; border-radius: 999rpx; }

.layer-status-pill {
  position: absolute;
  left: 18rpx;
  top: 134rpx;
  z-index: 22;
  max-width: 560rpx;
  padding: 9rpx 15rpx;
  color: #1a3551;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(201, 218, 238, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.11);
}

.layer-status-pill text {
  display: inline;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1.1;
}

.layer-status-pill text + text {
  margin-left: 12rpx;
  color: #657990;
  font-size: 15rpx;
  font-weight: 850;
}

.map3d-bottom-chip {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  z-index: 18;
  display: grid;
  grid-template-columns: 50rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  max-width: 560rpx;
  min-height: 54rpx;
  padding: 8rpx 14rpx 8rpx 9rpx;
  color: #20344f;
  background: rgba(255, 255, 255, 0.93);
  border: 2rpx solid rgba(207, 222, 241, 0.94);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 53, 94, 0.12);
}

.map3d-bottom-chip image {
  width: 48rpx;
  height: 48rpx;
}

.map3d-bottom-chip text {
  display: block;
  overflow: hidden;
  font-size: 18rpx;
  font-weight: 950;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map3d-bottom-chip text + text {
  color: #5e7189;
  font-size: 14rpx;
  font-weight: 850;
}

.map3d-guidance-strip {
  position: absolute;
  left: 14rpx;
  bottom: 14rpx;
  z-index: 28;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto minmax(0, 1.08fr) auto;
  align-items: center;
  gap: 9rpx;
  max-width: 720rpx;
  min-height: 58rpx;
  padding: 8rpx 10rpx;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(15, 28, 44, 0.94), rgba(7, 65, 135, 0.92));
  border: 2rpx solid rgba(146, 202, 255, 0.42);
  border-radius: 26rpx;
  box-shadow: 0 18rpx 38rpx rgba(6, 24, 56, 0.28);
}

.guidance-strip-step {
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: #1ac46d;
  border-radius: 50%;
  font-size: 14rpx;
  font-weight: 950;
}

.guidance-strip-node {
  min-width: 0;
}

.guidance-strip-node text {
  display: block;
  overflow: hidden;
  color: rgba(226, 238, 255, 0.74);
  font-size: 13rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guidance-strip-node .guidance-strong {
  color: #ffffff;
  font-size: 17rpx;
  font-weight: 950;
}

.guidance-strip-node.next .guidance-strong {
  color: #bfe0ff;
}

.guidance-arrow {
  color: rgba(255, 255, 255, 0.6);
  font-size: 18rpx;
  font-weight: 950;
}

.guidance-strip-distance {
  display: grid;
  place-items: center;
  min-width: 52rpx;
  min-height: 34rpx;
  padding: 0 10rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
  font-size: 15rpx;
  font-weight: 950;
}

.map-rail {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  z-index: 34;
  display: grid;
  align-content: center;
  gap: 9rpx;
}

.map-rail button {
  display: grid;
  place-items: center;
  width: 92rpx;
  height: 74rpx;
  padding: 0;
  color: #20344f;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 53, 94, 0.14);
  font-size: 19rpx;
  font-weight: 950;
  line-height: 74rpx;
}

.map-rail button::after,
.panel-close::after,
.quick-row button::after,
.layer-grid button::after,
.start-route-button::after {
  display: none;
}

.map-rail button.active {
  color: #ffffff;
  background: #0b6cff;
}

.panel-shade {
  position: absolute;
  inset: 0 104rpx 0 0;
  z-index: 38;
  background: rgba(11, 24, 40, 0.08);
}

.material-panel {
  position: absolute;
  right: 118rpx;
  bottom: 16rpx;
  z-index: 40;
  width: min(660rpx, 62vw);
  min-height: 178rpx;
  max-height: 74vh;
  box-sizing: border-box;
  padding: 16rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid rgba(201, 218, 238, 0.96);
  border-radius: 32rpx;
  box-shadow: 0 22rpx 58rpx rgba(20, 53, 94, 0.26);
}

.panel-card {
  display: grid;
  gap: 10rpx;
}

.panel-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  align-items: center;
  gap: 14rpx;
}

.panel-title {
  color: #17253a;
  font-size: 26rpx;
  font-weight: 950;
}

.panel-meta {
  color: #0b6cff;
  font-size: 20rpx;
  font-weight: 950;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  color: #405875;
  background: #eef4fb;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 44rpx;
}

.route-summary,
.room-detail {
  color: #566a82;
  font-size: 20rpx;
  font-weight: 850;
}

.muted {
  color: #7b8da3;
}

.step-strip {
  width: 100%;
  white-space: nowrap;
}

.step-card {
  display: inline-grid;
  vertical-align: top;
  width: 210rpx;
  min-height: 92rpx;
  box-sizing: border-box;
  margin-right: 10rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #edf5ff;
}

.step-card.stair {
  background: #fff1d5;
}

.step-card.target {
  background: #ffe9e6;
}

.step-no,
.step-title,
.step-desc {
  display: block;
}

.step-no {
  color: #0b6cff;
  font-size: 17rpx;
  font-weight: 950;
}

.step-title {
  margin-top: 4rpx;
  color: #17253a;
  font-size: 20rpx;
  font-weight: 950;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.step-desc {
  margin-top: 4rpx;
  color: #657a92;
  font-size: 16rpx;
  font-weight: 800;
  line-height: 1.22;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.quick-row,
.layer-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.quick-row button,
.layer-grid button {
  min-width: 108rpx;
  height: 48rpx;
  padding: 0 16rpx;
  color: #075bd4;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: #e5f0ff;
}

.quick-row button.plain {
  color: #61758d;
  background: #eef2f6;
}

.layer-grid button.active {
  color: #ffffff;
  background: #0b6cff;
}

.detail-title {
  display: block;
  color: #17253a;
  font-size: 24rpx;
  font-weight: 950;
}

.detail-desc {
  display: block;
  margin-top: 8rpx;
  color: #61758d;
  font-size: 19rpx;
  font-weight: 820;
  line-height: 1.35;
}

.start-route-button {
  width: 180rpx;
  height: 52rpx;
  margin: 12rpx 0 0;
  color: #ffffff;
  background: #0b6cff;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 52rpx;
}

.panel-note {
  color: #6b7d93;
  font-size: 17rpx;
  font-weight: 820;
  line-height: 1.25;
}

/* Kept as verification anchors for the native canvas renderer. */
.floor-deck,
.space-corridor,
.room,
.door,
.route-segment,
.stair,
.route-node {
  box-sizing: border-box;
}

@media (max-width: 700px) and (orientation: landscape) {
  .map-stage {
    right: 92rpx;
  }

  .map-rail button {
    width: 78rpx;
    height: 62rpx;
    border-radius: 20rpx;
    font-size: 17rpx;
    line-height: 62rpx;
  }

  .material-panel {
    right: 104rpx;
    width: min(560rpx, 62vw);
  }

  .map3d-guidance-strip {
    max-width: 560rpx;
  }

  .map-legend {
    display: none;
  }

  .layer-status-pill {
    top: 82rpx;
  }
}
